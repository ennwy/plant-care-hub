{
  "openapi": "3.0.0",
  "info": {
    "title": "plant-care-hub API",
    "version": "1.0.0",
    "description": "REST API for plant-care-hub, university coursework (lab 6)"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "local dev"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "plant.sid"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 20
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6
                  },
                  "city": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "sets session cookie": null
          },
          "400": {
            "description": "Validation error or username taken"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Log in by username and password",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged in",
            "sets session cookie": null
          },
          "401": {
            "description": "Wrong credentials"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Log out and destroy session",
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "Logged out"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Get currently logged-in user from session",
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "Returns user object"
          },
          "401": {
            "description": "Not logged in"
          }
        }
      }
    },
    "/api/plants": {
      "get": {
        "summary": "List all plants (public)",
        "tags": [
          "Plants"
        ],
        "responses": {
          "200": {
            "description": "Array of plants"
          }
        }
      },
      "post": {
        "summary": "Add a plant for the current user",
        "tags": [
          "Plants"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "species",
                  "nickname"
                ],
                "properties": {
                  "species": {
                    "type": "string"
                  },
                  "nickname": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 30
                  },
                  "acquired_at": {
                    "type": "string",
                    "format": "date"
                  },
                  "location": {
                    "type": "string"
                  },
                  "watering": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 30
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Plant created"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/plants/mine": {
      "get": {
        "summary": "List plants of the current user",
        "tags": [
          "Plants"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Array of user's plants"
          },
          "401": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/api/plants/{id}/water": {
      "post": {
        "summary": "Mark plant as watered (resets next_water)",
        "tags": [
          "Plants"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated plant"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/plants/{id}": {
      "delete": {
        "summary": "Delete a plant",
        "tags": [
          "Plants"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/tips": {
      "get": {
        "summary": "List community tips with pagination",
        "tags": [
          "Tips"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of tips"
          }
        }
      },
      "post": {
        "summary": "Publish a new tip",
        "tags": [
          "Tips"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "body"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 3
                  },
                  "body": {
                    "type": "string",
                    "minLength": 10
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tip created"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/tips/{id}/like": {
      "post": {
        "summary": "Like a tip",
        "tags": [
          "Tips"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated tip"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/users/me/stats": {
      "get": {
        "summary": "Stats for the current user",
        "tags": [
          "Users"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Counts of plants/tips/waterings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "plants": {
                      "type": "integer"
                    },
                    "tips": {
                      "type": "integer"
                    },
                    "waterings": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": []
}
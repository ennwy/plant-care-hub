# openweather api key: https://home.openweathermap.org/api_keys
VITE_OPENWEATHER_KEY=your_openweather_key_here

# perenual api key: https://perenual.com/docs/api
VITE_PERENUAL_KEY=your_perenual_key_here

# express session secret, generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_random_32_byte_hex
